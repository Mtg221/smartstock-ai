# ─── Base de données ──────────────────────────────────────────────────────────
DATABASE_URL=postgresql://smartstock:smartstock_secret@localhost:5432/smartstock
POSTGRES_USER=smartstock
POSTGRES_PASSWORD=smartstock_secret
POSTGRES_DB=smartstock

# ─── Redis ────────────────────────────────────────────────────────────────────
REDIS_URL=redis://:redis_secret@localhost:6379
REDIS_PASSWORD=redis_secret

# ─── JWT (générer avec : openssl rand -hex 64) ───────────────────────────────
JWT_SECRET=CHANGE_ME_generate_with_openssl_rand_hex_64
JWT_REFRESH_SECRET=CHANGE_ME_generate_with_openssl_rand_hex_64_different

# ─── Backend ──────────────────────────────────────────────────────────────────
PORT=4000
NODE_ENV=development
CLIENT_URL=http://localhost:3000
API_URL=http://localhost:4000
AI_SERVICE_URL=http://localhost:8000

# ─── Frontend ─────────────────────────────────────────────────────────────────
NEXT_PUBLIC_API_URL=http://localhost:4000

# ─── Email (Nodemailer) ───────────────────────────────────────────────────────
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=votre@email.com
SMTP_PASS=votre_app_password
EMAIL_FROM=SmartStock AI <noreply@smartstock.ai>

# ─── Upload fichiers (Cloudinary optionnel) ───────────────────────────────────
CLOUDINARY_CLOUD_NAME=
CLOUDINARY_API_KEY=
CLOUDINARY_API_SECRET=
